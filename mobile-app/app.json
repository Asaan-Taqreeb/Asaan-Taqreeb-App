{
  "expo": {
    "name": "Asaan Taqreeb",
    "slug": "AsaanTaqreeb",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/Logo.png",
    "scheme": "AsaanTaqreeb",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Asaan Taqreeb to access your location while you use the app to find nearby vendors.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Allow Asaan Taqreeb to access your location even when the app is in the background for real-time order tracking."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ECFEFF",
        "foregroundImage": "./assets/images/Logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mirzazain1.asaantaqreeb"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/Logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow location mobileapp to use your location"
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e2d4e503-a2cc-4b01-b01b-370a55658cf9"
      }
    }
  }
}
